nextflow_process {

    name "Test DNDS_BATCH module"
    script "../../../../modules/local/dnds_batch/main.nf"
    process "DNDS_BATCH"
    tag "modules"
    tag "dnds_batch"

    test("DNDS_BATCH runs on protein MSA + nucleotide reference") {

        when {
            process {
                """
                input[0] = Channel.of(
                    [ file("${projectDir}/assets/aln.fa", checkIfExists: true) ]
                )
                input[1] = file("${projectDir}/assets/test_nuc.fa", checkIfExists: true)
                """
            }
        }

        then {
            assertAll(
                { assert process.success },
                { assert process.out.tsv },
                { assert snapshot(process.out.tsv, process.out.versions).match() }
            )
        }
    }
}
